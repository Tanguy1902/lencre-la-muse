rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonction utilitaire pour vérifier si l'utilisateur est l'auteur du poème parent
    function isPoemAuthor(poemId) {
      return request.auth != null && get(/databases/$(database)/documents/poems/$(poemId)).data.authorId == request.auth.uid;
    }

    // Profils Utilisateurs
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /followers/{followerId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == followerId;
      }
      match /following/{followedId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      match /bookmarks/{poemId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // Poèmes
    match /poems/{poemId} {
      allow read: if resource.data.status == 'published' || (request.auth != null && request.auth.uid == resource.data.authorId);
      allow create: if request.auth != null;
      
      // L'auteur peut tout modifier. 
      // Les autres peuvent UNIQUEMENT modifier les compteurs via les fonctions dédiées.
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId || 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likesCount', 'commentsCount', 'updatedAt'])
      );
      
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      
      // Sous-collection Likes
      match /likes/{userId} {
        allow read: if true;
        // Autorise la suppression si c'est son propre like OU si c'est l'auteur du poème (pour le clean-up)
        allow write: if request.auth != null && (request.auth.uid == userId || isPoemAuthor(poemId));
      }

      // Sous-collection Commentaires
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        // L'auteur du commentaire OU l'auteur du poème peut modifier/supprimer
        allow update, delete: if request.auth != null && (request.auth.uid == resource.data.authorId || isPoemAuthor(poemId));
      }
    }
  }
}
